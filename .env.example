# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.


DATABASE_URL="postgresql://ci:ci@localhost:5432/ci"

# better-auth (generate with: openssl rand -base64 32)
BETTER_AUTH_SECRET="XXXXXXXXXXXXXXXXXX"

# Canonical app URL (used for auth callbacks, cookie domains)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ============================================================
# ClassroomSim
# ============================================================
# By default ClassroomSim runs on a deterministic MOCK provider — the full loop
# (15-18 student-agents + teacher-agents + live SVG) works with ZERO API keys.
# Real providers only activate when you opt in below.
# NB: ClassroomSim does NOT need DATABASE_URL / BETTER_AUTH_SECRET (auth is off).

# Persistance Mastra — Postgres (Neon). REQUISE, pas de fallback dans le code.
# Utilise l'endpoint POOLÉ Neon (…-pooler.…neon.tech) pour ne pas épuiser les
# connexions en serverless. Mastra crée ses propres tables préfixées `mastra_`,
# donc elle cohabite avec Prisma/better-auth dans la même base.
MASTRA_DB_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"

# --- Opt-in to real providers ---
# (a) Force ALL students onto ONE provider (cheap iteration). One of:
#     anthropic | openai | google | deepseek
# DEV_SINGLE_PROVIDER="openai"
# (b) OR enable the full multi-provider demo (each student uses its preferred provider):
# DEMO_MODE="false"

# --- Provider API keys (only needed for the modes above) ---
# ANTHROPIC_API_KEY=""
# OPENAI_API_KEY=""
# GOOGLE_GENERATIVE_AI_API_KEY=""
# DEEPSEEK_API_KEY=""

# --- Model overrides (optional; default OpenAI = gpt-5.4-mini) ---
# Pin the model id per provider (the "provider/" prefix is added automatically).
# <PROVIDER>_MODEL = base model ; <PROVIDER>_MODEL_STRONG = model for subtle profiles (N5/N6/anxieux).
# OPENAI_MODEL="gpt-5.4-mini"
# OPENAI_MODEL_STRONG="gpt-5.4-mini"
# ANTHROPIC_MODEL="claude-sonnet-4.6"
# GOOGLE_MODEL="gemini-2.5-flash"
# DEEPSEEK_MODEL="deepseek-v3.2"
#
# ▶ Recette « uniquement OpenAI + gpt-5.4-mini » :
#     DEV_SINGLE_PROVIDER=openai
#     OPENAI_API_KEY=sk-...
#   (gpt-5.4-mini est déjà le modèle OpenAI par défaut — rien d'autre à régler.)

# --- Tuning (optional) ---
# Parallel student calls (keeps real-provider fan-out within rate limits).
# CLASSROOM_CONCURRENCY="6"
# Mock streaming pace in ms/token (lower = snappier, 0 = instant).
# MOCK_TOKEN_DELAY_MS="5"